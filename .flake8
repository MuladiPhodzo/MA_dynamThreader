[flake8]
max-line-length = 100
max-complexity = 12
exclude =
    .git,
    __pycache__,
    build,
    dist,
    venv,
    .pytest_cache,
    .mypy_cache,
    .idea,
    *.spec
ignore =
    E203,
    E266,
    E501,
    W503,
    F403,

    E302,
    E731
per-file-ignores =
    src/main/python/advisor/GUI/*.py: F403,F401
    src/main/python/advisor/Telegram/*.py: F403,F401
statistics = True
show-source = True
